{
  "name": "pfmaster",
  "version": "1.0.0",
  "description": "Pet grooming and care management API",
  "main": "dist/api/index.js",
  "scripts": {
    "dev": "tsx watch api/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/api/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^2.1.3",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
