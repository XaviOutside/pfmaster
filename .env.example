# Application
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Sentry
SENTRY_DSN=
VITE_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Set to 'true' to report errors to Sentry in development
# SENTRY_DEV_REPORTING=true
# VITE_SENTRY_DEV_REPORTING=true

# Docker MySQL credentials — DATABASE_URL is built from these by docker-compose.yml
DB_ROOT_PASSWORD=rootpassword
DB_NAME=pfmaster
DB_USER=pfmaster
DB_PASSWORD=pfmaster

# Authentication (argon2id)
SESSION_DURATION_HOURS=24
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# Seed configuration
SEED_ADMIN_EMAIL=admin@peluclic.com
SEED_ADMIN_PASSWORD=change-me-in-production

# E2E test configuration (used by Playwright tests)
E2E_ADMIN_EMAIL=admin@peluclic.com
E2E_ADMIN_PASSWORD=change-me-in-production
E2E_API_URL=http://localhost:3000
