generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(200)
  status    Int      @db.TinyInt @default(1) // 0=inactive, 1=active
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model User {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         Int       @db.TinyInt @default(1) // 0=admin, 1=employee
  status       Int       @db.TinyInt @default(1) // 0=inactive, 1=active
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([companyId])
  @@map("users")
}

model Session {
  id        Int       @id @default(autoincrement())
  token     String    @unique @db.VarChar(36)
  userId    Int       @map("user_id") // ref: users.id — no FK constraint (per project rules)
  companyId Int       @map("company_id") // ref: companies.id — denormalized, no FK constraint (per project rules)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("sessions")
}

model Client {
  id        Int       @id @default(autoincrement())
  companyId Int       @default(1) @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  name      String    @db.VarChar(255)
  email     String    @db.VarChar(255)
  phone     String    @db.VarChar(50)
  phone2    String?   @db.VarChar(50)
  address   String?   @db.VarChar(255)
  status    Int       @db.TinyInt @default(1) // 0=inactive, 1=active
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  lastServiceDate DateTime? @map("last_service_date") @db.Date
  notes          String?   @db.Text

  @@index([companyId])
  @@map("clients")
}

model Pet {
  id          Int       @id @default(autoincrement())
  companyId   Int       @default(1) @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  client_id   Int       // ref: clients.id — no FK constraint (per project rules)
  name        String    @db.VarChar(255)
  species     String    @db.VarChar(100)
  breed       String    @db.VarChar(255)
  sex         Int       @db.TinyInt @default(0) // 0=unknown, 1=male, 2=female
  dateOfBirth DateTime? @map("date_of_birth") @db.Date
  weightKg    Decimal?  @map("weight_kg") @db.Decimal(5, 2)
  notes       String?   @db.Text
  status      Int       @db.TinyInt @default(1) // 0=inactive, 1=active
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([companyId])
  @@map("pets")
}

model Service {
  id              Int       @id @default(autoincrement())
  companyId       Int       @default(1) @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  name            String    @db.VarChar(255)
  description     String?   @db.Text
  durationMinutes Int?      @map("duration_minutes")
  price           Int       // cents (e.g. 2500 = $25.00)
  petId           Int?      @map("pet_id") // ref: pets.id — no FK constraint (per project rules)
  status          Int       @db.TinyInt @default(1) // 0=inactive, 1=active
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([companyId])
  @@index([petId])
  @@fulltext([name, description])
  @@map("services")
}

model Appointment {
  id          Int       @id @default(autoincrement())
  companyId   Int       @default(1) @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  pet_id      Int       // ref: pets.id — no FK constraint (per project rules)
  client_id   Int       // ref: clients.id — denormalized from pet on create (per project rules)
  scheduledAt DateTime  @map("scheduled_at")
  status      Int       @db.TinyInt @default(0) // 0=pending, 1=confirmed, 2=completed, 3=cancelled
  notes       String?   @db.VarChar(500)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([companyId])
  @@index([pet_id])
  @@index([client_id])
  @@index([scheduledAt])
  @@map("appointments")
}

model CompanySettings {
  id            Int      @id @default(autoincrement())
  companyId     Int      @default(1) @map("company_id") // ref: companies.id — no FK constraint (per project rules)
  companyName   String   @map("company_name") @db.VarChar(200)
  tagline       String?  @db.VarChar(100)
  workdays      Json     // array of integers 1–7 (Mon=1, Sun=7)
  workStartTime String   @map("work_start_time") @db.VarChar(5) // HH:MM format
  workEndTime   String   @map("work_end_time") @db.VarChar(5)   // HH:MM format
  defaultLang   Int      @map("default_lang") @db.TinyInt // 0=English, 1=Spanish
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("company_settings")
}
